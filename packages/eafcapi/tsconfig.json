{
	"compilerOptions": {
		"experimentalDecorators": true,
		"outDir": "./dist",
		"module": "commonjs",
		"target": "ES2017",  // ← CAMBIAR de "es6" a "ES2017" o superior
		"lib": [
			"ES2017",  // ← CAMBIAR también
			"ESNext.AsyncIterable",
			"DOM"
		],
		"alwaysStrict": true,
		"strict": true,
		"preserveConstEnums": true,
		"moduleResolution": "node",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"esModuleInterop": true,
		"emitDecoratorMetadata": true,
		"skipLibCheck": true
	},
	"include": [
		"src"
	]
}